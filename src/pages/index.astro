---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">

    <!-- ========== Hero ========== -->
    <section id="hero" class="pt-12 pb-10 sm:pt-16 sm:pb-12 border-b border-border">
      <div class="max-w-prose space-y-4 text-base leading-relaxed opacity-80 sm:text-lg">
        <p>
          It's a pleasure to have you here.
        </p>
        <p>
          This is my quiet online corner — a personal blog where I gather
          words and reflections from my ongoing journey of learning and
          thinking.
        </p>
        <p>
          I started this blog for two simple reasons. Countless unique and
          interesting thoughts keep popping up in my mind each day, and I
          feel a strong urge to write them down and share them with others.
          Beyond that, I have long dreamed of having a blog of my own. To
          me, it is a special personal space on the internet: a place open
          for everyone to visit and explore my ideas. As someone passionate
          about technology and intellectual exploration, I also find
          building and running this independent site incredibly cool and
          rewarding.
        </p>
        <p>
          Hope you enjoy your stay.
        </p>
      </div>

      <!-- Social -->
      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2">
        <span class="text-sm opacity-50">Find me on</span>
        {
          SOCIALS.length > 0 && <Socials />
        }
      </div>
    </section>

    <!-- ========== Featured Posts ========== -->
    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-10 pb-6 sm:pt-12",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="mb-6 flex items-center gap-2">
            <span class="text-lg opacity-50" aria-hidden="true">★</span>
            <h2 class="text-xl font-semibold tracking-wide">Featured</h2>
          </div>
          <div class="space-y-4">
            {featuredPosts.map(data => (
              <Card variant="featured" {...data} />
            ))}
          </div>
        </section>
      )
    }

    <!-- ========== Recent Posts ========== -->
    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-10 pb-6 sm:pt-12">
          <h2 class="mb-6 text-xl font-semibold tracking-wide">Recent Posts</h2>
          <ul class="divide-y divide-border">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && (
                  <Card variant="compact" {...data} />
                )
            )}
          </ul>
        </section>
      )
    }

    <div class="my-10 text-center">
      <LinkButton href="/posts/">
        Browse All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

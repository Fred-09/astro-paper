---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import ShadeTitle from "@/assets/head.svg";

import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-0 z-40 bg-background/80 backdrop-blur-md"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "app-layout py-2 sm:py-3",
      "border-b border-border",
      "flex items-center justify-between",
    ]}
  >
    <!-- Logo -->
    <a
      href="/"
      class="z-10 flex-shrink-0 py-0 text-xl leading-8 font-semibold whitespace-nowrap sm:my-auto sm:text-2xl sm:leading-none"
    >
      <ShadeTitle class="h-[36px] w-auto sm:h-[50px] dark:invert" />
    </a>

    <nav
      id="nav-menu"
      class="flex w-full flex-col items-end sm:ms-6 sm:flex-row sm:items-center sm:justify-end sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline z-10 flex-shrink-0 p-2 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>

      <ul
        id="menu-items"
        class:list={[
          "mt-3 w-full flex flex-col divide-y divide-border rounded-lg border border-border bg-muted/20",
          "[&>li>a]:block [&>li>a]:px-5 [&>li>a]:py-3.5 [&>li>a]:text-base [&>li>a]:font-medium [&>li>a]:hover:text-accent [&>li>a]:text-center",
          "hidden",
          "sm:mt-0 sm:w-auto sm:flex sm:flex-row sm:items-center sm:divide-y-0 sm:rounded-none sm:border-0 sm:bg-transparent",
          "sm:[&>li>a]:px-2 sm:[&>li>a]:py-0.5 sm:[&>li>a]:text-base",
          "sm:gap-x-3",
        ]}
      >
        <li>
          <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>Posts</a>
        </li>
        <li>
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>Tags</a>
        </li>
        <li>
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>About</a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <a href="/archives" class:list={{ "active-nav": isActive("/archives") }}>Archives</a>
            </li>
          )
        }
        <!-- Search + Theme on one row -->
        <li>
          <div class="flex items-center justify-center gap-3 px-5 py-3 sm:px-1 sm:py-0">
            <a
              href="/search"
              class:list={[
                "focus-outline flex px-1 py-0.5 sm:px-2",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="Search"
              aria-label="search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
            </a>
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="focus-outline relative size-10 p-3 sm:size-8 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              )
            }
          </div>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  document.addEventListener("astro:after-swap", toggleNav);
</script>

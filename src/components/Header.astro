---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import ShadeTitle from "@/assets/head.svg";

import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const linkClass = (path: string) =>
  `px-2 py-0.5 text-base${isActive(path) ? " active-nav" : ""}`;
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="sticky top-0 z-40 bg-background/80 backdrop-blur-md">
  <div
    class="app-layout py-2 sm:py-3 border-b border-border flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <ShadeTitle class="h-[32px] w-auto sm:h-[44px] dark:invert" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-x-3 sm:flex">
      <a href="/posts" class={linkClass("/posts")}>Posts</a>
      <a href="/tags" class={linkClass("/tags")}>Tags</a>
      <a href="/about" class={linkClass("/about")}>About</a>
      {SITE.showArchives && <a href="/archives" class={linkClass("/archives")}>Archives</a>}
      <a href="/search" class:list={["px-2 py-0.5", { "[&>svg]:stroke-accent": isActive("/search") }]} title="Search" aria-label="search">
        <IconSearch />
      </a>
      {SITE.lightAndDarkMode && (
        <button id="theme-btn-desktop" class="relative size-8 p-1 hover:[&>svg]:stroke-accent" title="Toggle theme" aria-label="auto">
          <IconMoon class="absolute inset-0 m-auto scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
          <IconSunHigh class="absolute inset-0 m-auto scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
        </button>
      )}
    </nav>

    <!-- Mobile hamburger + dropdown -->
    <div class="relative sm:hidden">
      <button
        id="menu-btn"
        class="p-2"
        aria-label="Open Menu" aria-expanded="false" aria-controls="mobile-menu"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <div
        id="mobile-menu"
        class="absolute right-0 top-full mt-2 hidden w-48 rounded-lg border border-border bg-background py-2 shadow-lg"
      >
        <a href="/posts" class="block px-4 py-2.5 text-center text-base font-medium hover:text-accent">Posts</a>
        <a href="/tags" class="block px-4 py-2.5 text-center text-base font-medium hover:text-accent">Tags</a>
        <a href="/about" class="block px-4 py-2.5 text-center text-base font-medium hover:text-accent">About</a>
        {SITE.showArchives && <a href="/archives" class="block px-4 py-2.5 text-center text-base font-medium hover:text-accent">Archives</a>}
        <div class="mt-1 flex items-center justify-center gap-4 border-t border-border pt-2">
          <a href="/search" class:list={["p-2", { "[&>svg]:stroke-accent": isActive("/search") }]} title="Search" aria-label="search">
            <IconSearch />
          </a>
          {SITE.lightAndDarkMode && (
            <button id="theme-btn-mobile" class="relative size-9 p-1.5 hover:[&>svg]:stroke-accent" title="Toggle theme" aria-label="auto">
              <IconMoon class="absolute inset-0 m-auto scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
              <IconSunHigh class="absolute inset-0 m-auto scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
            </button>
          )}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function setup() {
    const btn = document.querySelector("#menu-btn") as HTMLElement | null;
    const menu = document.querySelector("#mobile-menu") as HTMLElement | null;
    const menuIcon = document.querySelector("#menu-icon") as HTMLElement | null;
    const closeIcon = document.querySelector("#close-icon") as HTMLElement | null;
    if (!btn || !menu || !menuIcon || !closeIcon) return;

    btn.addEventListener("click", () => {
      const open = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", open ? "false" : "true");
      btn.setAttribute("aria-label", open ? "Open Menu" : "Close Menu");
      menu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });

    menu.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Open Menu");
      });
    });

    // Sync theme buttons
    const dt = document.querySelector("#theme-btn-desktop") as HTMLElement | null;
    const mb = document.querySelector("#theme-btn-mobile") as HTMLElement | null;
    if (dt && mb) mb.addEventListener("click", () => dt.click());
  }

  setup();
  document.addEventListener("astro:after-swap", setup);
</script>

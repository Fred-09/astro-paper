---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import ShadeTitle from "@/assets/head.svg";

import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-0 z-40 bg-background/80 backdrop-blur-md"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "app-layout py-2 sm:py-3",
      "border-b border-border",
      "flex items-center justify-between",
    ]}
  >
    <!-- Logo -->
    <a
      href="/"
      class="z-10 flex-shrink-0 py-0 text-xl leading-8 font-semibold whitespace-nowrap sm:my-auto sm:text-2xl sm:leading-none"
    >
      <ShadeTitle class="h-[36px] w-auto sm:h-[50px] dark:invert" />
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="focus-outline z-30 flex-shrink-0 p-2 sm:hidden"
      aria-label="Open Menu"
      aria-expanded="false"
      aria-controls="menu-items"
    >
      <IconX id="close-icon" class="hidden" />
      <IconMenuDeep id="menu-icon" />
    </button>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex sm:flex-row sm:items-center sm:gap-x-3">
      <a href="/posts" class:list={["px-2 py-0.5 text-base", { "active-nav": isActive("/posts") }]}>Posts</a>
      <a href="/tags" class:list={["px-2 py-0.5 text-base", { "active-nav": isActive("/tags") }]}>Tags</a>
      <a href="/about" class:list={["px-2 py-0.5 text-base", { "active-nav": isActive("/about") }]}>About</a>
      {
        SITE.showArchives && (
          <a href="/archives" class:list={["px-2 py-0.5 text-base", { "active-nav": isActive("/archives") }]}>Archives</a>
        )
      }
      <a
        href="/search"
        class:list={["px-2 py-0.5", { "[&>svg]:stroke-accent": isActive("/search") }]}
        title="Search" aria-label="search"
      >
        <IconSearch />
      </a>
      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-8 p-1 hover:[&>svg]:stroke-accent"
            title="Toggles light & dark" aria-label="auto" aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )
      }
    </nav>

    <!-- Mobile menu overlay -->
    <div
      id="menu-items"
      class="fixed inset-0 top-0 z-20 hidden bg-background/95 backdrop-blur-sm sm:hidden"
    >
      <ul class="flex flex-col items-center justify-center h-full gap-2 px-8">
        <li><a href="/posts" class:list={["block px-6 py-3 text-xl font-medium", { "active-nav": isActive("/posts") }]}>Posts</a></li>
        <li><a href="/tags" class:list={["block px-6 py-3 text-xl font-medium", { "active-nav": isActive("/tags") }]}>Tags</a></li>
        <li><a href="/about" class:list={["block px-6 py-3 text-xl font-medium", { "active-nav": isActive("/about") }]}>About</a></li>
        {
          SITE.showArchives && (
            <li><a href="/archives" class:list={["block px-6 py-3 text-xl font-medium", { "active-nav": isActive("/archives") }]}>Archives</a></li>
          )
        }
        <li class="flex items-center gap-6 pt-4">
          <a href="/search" class:list={["p-2", { "[&>svg]:stroke-accent": isActive("/search") }]} title="Search" aria-label="search">
            <IconSearch />
          </a>
          {
            SITE.lightAndDarkMode && (
              <button id="theme-btn-mobile" class="focus-outline relative size-10 p-2 hover:[&>svg]:stroke-accent" title="Toggles light & dark" aria-label="auto">
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            )
          }
        </li>
      </ul>
    </div>
        <li>
          <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>Posts</a>
        </li>
        <li>
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>Tags</a>
        </li>
        <li>
          <a href="/about" class:list={{ "active-nav": isActive("/about") }}>About</a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <a href="/archives" class:list={{ "active-nav": isActive("/archives") }}>Archives</a>
            </li>
          )
        }
        <!-- Search + Theme on one row -->
        <li>
          <div class="flex items-center justify-center gap-3 px-5 py-3 sm:px-1 sm:py-0">
            <a
              href="/search"
              class:list={[
                "focus-outline flex px-1 py-0.5 sm:px-2",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="Search"
              aria-label="search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
            </a>
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="focus-outline relative size-10 p-3 sm:size-8 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              )
            }
          </div>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");

      // Prevent body scroll when menu is open
      document.body.classList.toggle("overflow-hidden", !openMenu);
    });

    // Close menu when tapping a link
    menuItems.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        menuItems.classList.add("hidden");
        menuIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        menuBtn?.setAttribute("aria-expanded", "false");
        menuBtn?.setAttribute("aria-label", "Open Menu");
        document.body.classList.remove("overflow-hidden");
      });
    });

    // Sync both theme buttons
    const desktopThemeBtn = document.querySelector("#theme-btn");
    const mobileThemeBtn = document.querySelector("#theme-btn-mobile");
    if (desktopThemeBtn && mobileThemeBtn) {
      mobileThemeBtn.addEventListener("click", () => {
        (desktopThemeBtn as HTMLElement).click();
      });
    }
  }

  toggleNav();

  document.addEventListener("astro:after-swap", toggleNav);
</script>

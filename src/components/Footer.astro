---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import IconRss from "@/assets/icons/IconRss.svg";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="border-t border-border py-8">
    <!-- Icons -->
    <div class="flex items-center justify-center gap-3">
      <Socials />
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-sm opacity-50 transition-colors hover:text-accent hover:opacity-100"
        title="RSS Feed"
      >
        <IconRss class="size-4" />
        <span>RSS</span>
      </a>
    </div>

    <!-- Copyright -->
    <p class="mt-3 text-center text-sm opacity-40">
      &copy; {currentYear} Frederick Song
    </p>
  </div>
</footer>
